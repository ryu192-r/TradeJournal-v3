# Environment variables for Trading Journal v3

# PostgreSQL
POSTGRES_USER=trading_journal
POSTGRES_PASSWORD=securepassword
POSTGRES_DB=trading_journal

# Backend
DATABASE_URL=postgresql://trading_journal:securepassword@localhost:5432/trading_journal
BACKEND_PORT=8000

# Security — MUST be long random strings in production
SECRET_KEY=change-me-to-a-long-random-string
JWT_SECRET_KEY=change-me-to-a-different-long-random-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
REFRESH_TOKEN_REUSE_REVOKE_ALL=true

# Frontend
FRONTEND_PORT=3000
REACT_APP_API_URL=http://localhost:8000

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Backup settings
BACKUP_DIR=/backups
MAX_BACKUPS=30