# Environment variables for Trading Journal v3
#
# Deployment note: never reuse local sample or test values in production.
# Rotate any Telegram token, DB password, SECRET_KEY, or JWT_SECRET_KEY that
# was ever shared, committed, printed in logs, or used during local testing.

# PostgreSQL
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=

# Backend
DATABASE_URL=
BACKEND_PORT=8000

# Security — required. Generate unique values, for example:
# openssl rand -hex 32
SECRET_KEY=
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
REFRESH_TOKEN_REUSE_REVOKE_ALL=true
RATE_LIMIT_OFF=false
ALLOW_LOCAL_AI_URLS=false

# Frontend
FRONTEND_PORT=3000
REACT_APP_API_URL=http://localhost:8000

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Tapetide daily chart provider (optional)
TAPETIDE_ENABLED=true
TAPETIDE_MCP_URL=https://mcp.tapetide.com/mcp
TAPETIDE_API_KEY=
TAPETIDE_DEFAULT_EXCHANGE=NSE

# Backup settings
BACKUP_DIR=/backups
MAX_BACKUPS=30
