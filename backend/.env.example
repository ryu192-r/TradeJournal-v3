# Environment variables for Trading Journal v3

# Database settings
DATABASE_URL=postgresql://user:password@localhost/trading_journal

# API settings
DEBUG=True
LOG_LEVEL=INFO

# Security settings — MUST be long random strings in production
SECRET_KEY=change-me-to-a-long-random-string-at-least-32-chars
JWT_SECRET_KEY=change-me-to-a-different-long-random-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
REFRESH_TOKEN_REUSE_REVOKE_ALL=true