# Environment variables for Trading Journal v3

# Database settings
DATABASE_URL=postgresql://user:password@localhost/trading_journal

# API settings
DEBUG=True
LOG_LEVEL=INFO

# Security settings — MUST be long random strings in production
SECRET_KEY=change-me-to-a-long-random-string-at-least-32-chars
JWT_SECRET_KEY=change-me-to-a-different-long-random-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
REFRESH_TOKEN_REUSE_REVOKE_ALL=true
RATE_LIMIT_OFF=false

# Dhan broker integration (optional — enables historical candle data for charts)
DHAN_CLIENT_ID=
DHAN_ACCESS_TOKEN=

# Market data provider (optional — for candle data providers)
MARKET_DATA_API_URL=
MARKET_DATA_API_KEY=

# Tapetide daily chart provider (optional — enables OHLCV charts)
TAPETIDE_ENABLED=true
TAPETIDE_MCP_URL=https://mcp.tapetide.com/mcp
TAPETIDE_API_KEY=
TAPETIDE_DEFAULT_EXCHANGE=NSE

# Uploads
UPLOAD_DIR=uploads/charts
MAX_UPLOAD_SIZE_MB=10
