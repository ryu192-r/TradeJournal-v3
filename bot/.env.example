# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# Backend API
BACKEND_URL=http://backend:8000/api/v1

# Scheduled job times (IST = UTC+5:30)
# Market opens 9:15 IST, closes 3:30 IST
PRE_MARKET_TIME=03:15    # 03:15 UTC = 08:45 IST
POST_MARKET_TIME=10:00   # 10:00 UTC = 15:30 IST
REMINDER_INTERVAL_MINUTES=120

# Database
DATABASE_URL=postgresql://user:pass@postgres:5432/trading_journal_db
LOG_LEVEL=INFO
